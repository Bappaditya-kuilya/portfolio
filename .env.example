# Contact form (Formspree) — lets visitors send mail without leaving the site.
# Sign up at formspree.io, create a form, paste its endpoint here.
# If left blank, the form falls back to opening the visitor's email app.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# Canonical site URL — used for SEO metadata, sitemap, and OG tags.
NEXT_PUBLIC_SITE_URL=https://bappadityakuilya.is-a.dev

# Google Search Console verification token (Settings → HTML tag → content="...").
# Required to claim the site so it ranks on searches for your name.
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Optional GitHub token (read-only, no scopes needed for public data).
# Raises the GitHub API rate limit from 60/hr to 5000/hr and enables the
# authenticated contribution calendar. Set in Vercel project env vars.
GITHUB_TOKEN=
